---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'FreeMCP.in — The Open-Source MCP Server Registry',
  description = 'Discover, compare, and connect 100% free and open-source Model Context Protocol servers. Purpose-built for AI engineers working with LangGraph, LangChain, CrewAI, and autonomous DevSecOps agents.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050510" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://freemcp.in" />
    <meta property="og:site_name" content="FreeMCP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href="https://freemcp.in" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      /* ─── Design Tokens ─── */
      :root {
        --bg-deep: #050510;
        --bg-base: #0a0a1a;
        --bg-surface: #0f0f23;
        --bg-elevated: #141432;
        --bg-card: rgba(15, 15, 35, 0.6);
        --bg-card-hover: rgba(20, 20, 50, 0.8);
        --border-subtle: rgba(255, 255, 255, 0.04);
        --border-default: rgba(255, 255, 255, 0.06);
        --border-hover: rgba(255, 255, 255, 0.1);
        --border-accent: rgba(99, 102, 241, 0.3);
        --text-primary: #f0f0f8;
        --text-secondary: #a0a0c0;
        --text-tertiary: #606080;
        --text-muted: #40405a;
        --accent-primary: #6366f1;
        --accent-secondary: #818cf8;
        --accent-glow: rgba(99, 102, 241, 0.15);
        --cyan: #22d3ee;
        --emerald: #34d399;
        --rose: #fb7185;
        --amber: #fbbf24;
        --violet: #a78bfa;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        background: var(--bg-deep);
        color: var(--text-primary);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* ─── Scrollbar ─── */
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: rgba(99, 102, 241, 0.2); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: rgba(99, 102, 241, 0.4); }

      /* ─── Selection ─── */
      ::selection { background: rgba(99, 102, 241, 0.3); color: #fff; }

      /* ─── Global Animations ─── */
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }

      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes glow-pulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 0.8; }
      }

      @keyframes gradient-shift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      @keyframes border-glow {
        0%, 100% { border-color: rgba(99, 102, 241, 0.1); }
        50% { border-color: rgba(99, 102, 241, 0.3); }
      }

      .animate-fade-up {
        animation: fadeUp 0.6s ease-out both;
      }

      /* ─── Utility classes ─── */
      .glass {
        background: rgba(15, 15, 35, 0.5);
        backdrop-filter: blur(20px) saturate(1.2);
        -webkit-backdrop-filter: blur(20px) saturate(1.2);
      }

      .glass-card {
        background: linear-gradient(135deg, rgba(15, 15, 35, 0.7), rgba(10, 10, 26, 0.9));
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-default);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .glass-card:hover {
        border-color: var(--border-hover);
        background: linear-gradient(135deg, rgba(20, 20, 50, 0.8), rgba(15, 15, 35, 0.95));
        box-shadow:
          0 0 0 1px rgba(99, 102, 241, 0.08),
          0 8px 40px rgba(0, 0, 0, 0.4),
          0 0 60px rgba(99, 102, 241, 0.04);
        transform: translateY(-2px);
      }

      .gradient-text {
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 30%, #22d3ee 70%, #34d399 100%);
        background-size: 200% auto;
        animation: gradient-shift 6s ease infinite;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .btn-primary {
        position: relative;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        overflow: hidden;
      }

      .btn-primary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #818cf8, #6366f1);
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 30px rgba(99, 102, 241, 0.4), 0 0 0 1px rgba(99, 102, 241, 0.2);
      }

      .btn-primary:hover::before {
        opacity: 1;
      }

      .btn-primary > * {
        position: relative;
        z-index: 1;
      }

      .btn-secondary {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border-default);
        color: var(--text-secondary);
        border-radius: 10px;
        font-weight: 500;
        transition: all 0.3s ease;
      }

      .btn-secondary:hover {
        border-color: var(--border-hover);
        background: rgba(255, 255, 255, 0.06);
        color: var(--text-primary);
        transform: translateY(-1px);
      }

      /* line clamp */
      .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    </style>
  </head>

  <body>
    <!-- ─── Ambient Background ─── -->
    <div style="position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;" aria-hidden="true">
      <!-- Primary orb -->
      <div style="position:absolute;top:-20%;left:20%;width:800px;height:800px;border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.08) 0%,rgba(99,102,241,0.02) 40%,transparent 70%);animation:glow-pulse 8s ease-in-out infinite;"></div>
      <!-- Secondary orb -->
      <div style="position:absolute;bottom:-10%;right:10%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(34,211,238,0.05) 0%,transparent 60%);animation:glow-pulse 10s ease-in-out infinite 2s;"></div>
      <!-- Grid overlay -->
      <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 75%);"></div>
    </div>

    <!-- ─── Navigation ─── -->
    <nav class="glass" style="position:sticky;top:0;z-index:50;border-bottom:1px solid var(--border-subtle);">
      <div style="max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;">
        <!-- Logo -->
        <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:inherit;" id="nav-logo">
          <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#6366f1,#818cf8);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(99,102,241,0.3);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <span style="font-size:15px;font-weight:700;letter-spacing:-0.02em;">Free<span style="color:#818cf8;">MCP</span></span>
        </a>

        <!-- Nav links — desktop -->
        <div style="display:flex;align-items:center;gap:8px;" class="nav-desktop">
          <a href="#registry" style="padding:8px 14px;font-size:13px;color:var(--text-tertiary);text-decoration:none;border-radius:8px;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">Registry</a>
          <a href="#how-it-works" style="padding:8px 14px;font-size:13px;color:var(--text-tertiary);text-decoration:none;border-radius:8px;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">How It Works</a>
          <a href="#about" style="padding:8px 14px;font-size:13px;color:var(--text-tertiary);text-decoration:none;border-radius:8px;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">About</a>
          <div style="width:1px;height:20px;background:var(--border-default);margin:0 4px;"></div>
          <a href="https://github.com/strbbrn/freemcp-registry" target="_blank" rel="noopener noreferrer" style="padding:8px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;display:flex;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a
            href="https://github.com/strbbrn/freemcp-registry/issues/new?template=submit-server.md"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            style="padding:8px 16px;font-size:13px;display:inline-flex;align-items:center;gap:6px;text-decoration:none;"
            id="nav-submit-btn"
          >
            <span style="display:flex;align-items:center;gap:6px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              Submit Server
            </span>
          </a>
        </div>

        <!-- Mobile submit -->
        <a
          href="https://github.com/strbbrn/freemcp-registry/issues/new?template=submit-server.md"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary nav-mobile"
          style="padding:7px 14px;font-size:12px;display:none;align-items:center;gap:5px;text-decoration:none;"
        >
          <span style="display:flex;align-items:center;gap:5px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            Submit
          </span>
        </a>
      </div>
    </nav>

    <!-- ─── Content ─── -->
    <main style="position:relative;z-index:1;">
      <slot />
    </main>

    <!-- ─── Footer ─── -->
    <footer id="about" style="position:relative;z-index:1;border-top:1px solid var(--border-subtle);margin-top:80px;">
      <div style="max-width:1200px;margin:0 auto;padding:48px 24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;">
          <!-- Brand -->
          <div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
              <div style="width:24px;height:24px;border-radius:6px;background:linear-gradient(135deg,#6366f1,#818cf8);display:flex;align-items:center;justify-content:center;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <span style="font-weight:700;font-size:14px;">Free<span style="color:#818cf8;">MCP</span></span>
            </div>
            <p style="font-size:13px;color:var(--text-tertiary);line-height:1.7;max-width:280px;">
              The community hub for 100% free and open-source MCP servers. No paywalls. No enterprise tiers. Built for engineers who ship.
            </p>
          </div>

          <!-- Resources -->
          <div>
            <p style="font-size:12px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;">Resources</p>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">MCP Specification ↗</a>
              <a href="https://github.com/modelcontextprotocol/servers" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">Official MCP Servers ↗</a>
              <a href="https://python.langchain.com/docs/integrations/tools/" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">LangChain Tools ↗</a>
              <a href="https://langchain-ai.github.io/langgraph/" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">LangGraph Docs ↗</a>
            </div>
          </div>

          <!-- Community -->
          <div>
            <p style="font-size:12px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;">Community</p>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <a href="https://github.com/strbbrn/freemcp-registry" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">GitHub Repository ↗</a>
              <a href="https://github.com/strbbrn/freemcp-registry/issues/new" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">Submit a Server ↗</a>
              <a href="https://github.com/strbbrn/freemcp-registry/discussions" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">Discussions ↗</a>
            </div>
          </div>
        </div>

        <!-- Bottom bar -->
        <div style="margin-top:40px;padding-top:24px;border-top:1px solid var(--border-subtle);display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:12px;">
          <p style="font-size:12px;color:var(--text-muted);">
            © 2026 FreeMCP.in · Open Source · <a href="https://autonomousagents.in/" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">Autonomous Agents </a>
          </p>
          <p style="font-size:12px;color:var(--text-muted);">
<a href="https://github.com/strbbrn/" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--text-tertiary);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text-secondary)'" onmouseout="this.style.color='var(--text-tertiary)'">Contact me</a> · Cloudflare Pages
          </p>
        </div>
      </div>
    </footer>

    <style>
      @media (max-width: 640px) {
        .nav-desktop { display: none !important; }
        .nav-mobile { display: inline-flex !important; }
      }
    </style>
  </body>
</html>
