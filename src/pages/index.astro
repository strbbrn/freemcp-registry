---
import Layout from '../layouts/Layout.astro';
import registry from '../data/registry.json';

const categories = ['All', ...new Set(registry.map((s) => s.category))].sort((a, b) =>
  a === 'All' ? -1 : b === 'All' ? 1 : a.localeCompare(b)
);

const totalServers = registry.length;
const totalCategories = categories.length - 1;

const categoryIcons = {
  Database: '⬡',
  Development: '⌘',
  Security: '⛨',
  DevOps: '◎',
  Utilities: '◈',
  Search: '◉',
  Communication: '◇',
  Cloud: '☁',
};

const categoryColors = {
  Database: { text: '#34d399', bg: 'rgba(52,211,153,0.08)', border: 'rgba(52,211,153,0.15)' },
  Development: { text: '#818cf8', bg: 'rgba(129,140,248,0.08)', border: 'rgba(129,140,248,0.15)' },
  Security: { text: '#fb7185', bg: 'rgba(251,113,133,0.08)', border: 'rgba(251,113,133,0.15)' },
  DevOps: { text: '#fb923c', bg: 'rgba(251,146,60,0.08)', border: 'rgba(251,146,60,0.15)' },
  Utilities: { text: '#a78bfa', bg: 'rgba(167,139,250,0.08)', border: 'rgba(167,139,250,0.15)' },
  Search: { text: '#fbbf24', bg: 'rgba(251,191,36,0.08)', border: 'rgba(251,191,36,0.15)' },
  Communication: { text: '#f472b6', bg: 'rgba(244,114,182,0.08)', border: 'rgba(244,114,182,0.15)' },
  Cloud: { text: '#38bdf8', bg: 'rgba(56,189,248,0.08)', border: 'rgba(56,189,248,0.15)' },
};
---

<Layout>
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!--                           HERO SECTION                            -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <section style="position:relative;overflow:hidden;padding:80px 24px 60px;">
    <!-- Hero glow -->
    <div style="position:absolute;top:-200px;left:50%;transform:translateX(-50%);width:1000px;height:600px;border-radius:50%;background:radial-gradient(ellipse,rgba(99,102,241,0.12) 0%,rgba(99,102,241,0.04) 35%,transparent 65%);pointer-events:none;" aria-hidden="true"></div>

    <div style="position:relative;max-width:800px;margin:0 auto;text-align:center;">
      <!-- Announcement pill -->
      <div style="margin-bottom:28px;display:inline-flex;align-items:center;gap:8px;padding:6px 16px 6px 8px;border-radius:100px;border:1px solid var(--border-default);background:rgba(99,102,241,0.05);font-size:12px;color:var(--text-secondary);backdrop-filter:blur(8px);" class="animate-fade-up">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#818cf8);">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        </span>
        <span style="color:var(--text-tertiary);">Community-curated</span>
        <span style="color:var(--accent-secondary);font-weight:600;">{totalServers} servers</span>
        <span style="color:var(--text-tertiary);">and counting</span>
      </div>

      <!-- Headline -->
      <h1 style="font-size:clamp(2.2rem,5.5vw,3.8rem);font-weight:800;line-height:1.08;letter-spacing:-0.035em;margin-bottom:20px;" class="animate-fade-up">
        <span style="display:block;color:var(--text-primary);">The open registry for</span>
        <span class="gradient-text" style="display:block;">MCP servers</span>
      </h1>

      <!-- Subtitle -->
      <p style="font-size:clamp(0.95rem,1.8vw,1.1rem);color:var(--text-tertiary);line-height:1.7;max-width:560px;margin:0 auto 36px;" class="animate-fade-up">
        Discover and connect free, open-source Model Context Protocol servers.
        Built for AI engineers shipping with LangGraph, LangChain, and CrewAI.
      </p>

      <!-- CTAs -->
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-bottom:56px;" class="animate-fade-up">
        <a href="#registry" class="btn-primary" style="padding:12px 24px;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
          <span style="display:flex;align-items:center;gap:8px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Browse Registry
          </span>
        </a>
        <a href="https://github.com/strbbrn/freemcp-registry" target="_blank" rel="noopener noreferrer" class="btn-secondary" style="padding:12px 24px;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>

      <!-- Stats bar -->
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;border-radius:16px;overflow:hidden;background:var(--border-subtle);max-width:600px;margin:0 auto;" class="animate-fade-up">
        {[
          { label: 'MCP Servers', value: totalServers + '+' },
          { label: 'Categories', value: String(totalCategories) },
          { label: 'License', value: 'MIT' },
          { label: 'Infra Cost', value: '$0/mo' },
        ].map((stat) => (
          <div style="padding:20px 16px;text-align:center;background:var(--bg-surface);">
            <div style="font-size:20px;font-weight:700;color:var(--text-primary);letter-spacing:-0.02em;font-variant-numeric:tabular-nums;">{stat.value}</div>
            <div style="font-size:11px;color:var(--text-tertiary);margin-top:4px;text-transform:uppercase;letter-spacing:0.06em;font-weight:500;">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Trusted-by line -->
      <p style="margin-top:28px;font-size:11px;color:var(--text-muted);letter-spacing:0.04em;">
        WORKS WITH CLAUDE DESKTOP · CURSOR · LANGCHAIN · LANGGRAPH · CREWAI
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!--                         REGISTRY SECTION                          -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <section id="registry" style="max-width:1200px;margin:0 auto;padding:0 24px 80px;">
    <!-- ─── Sponsored Banner ─── -->
    <div class="glass-card animate-fade-up" style="margin-bottom:32px;padding:20px;border-radius:16px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--border-accent);background:linear-gradient(135deg,rgba(99,102,241,0.03),rgba(15,15,35,0.6));">
      <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap;">
        <div style="width:120px;height:80px;background:rgba(255,255,255,0.02);border:1px dashed var(--border-hover);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;flex-shrink:0;">
          Ad Space
        </div>
        <div>
          <h4 style="font-size:14px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:6px;">
            Sponsor FreeMCP
            <span style="font-size:9px;font-weight:600;color:var(--cyan);background:rgba(34,211,238,0.08);padding:1px 6px;border-radius:4px;border:1px solid rgba(34,211,238,0.15);letter-spacing:0.05em;">SPONSOR</span>
          </h4>
          <p style="font-size:13px;color:var(--text-tertiary);margin-top:6px;max-width:640px;line-height:1.6;">
            Reach thousands of AI developers, engineers, and builders searching for tools to power Claude Desktop, Cursor, LangGraph, and CrewAI.
          </p>
        </div>
      </div>
      <a href="mailto:agents@freemcp.in?subject=Sponsorship%20Inquiry" class="btn-primary" style="padding:10px 18px;font-size:12px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;">
        Advertise Here
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    </div>

    <!-- Section header + search -->
    <div style="margin-bottom:28px;">
      <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end;justify-content:space-between;">
        <div>
          <h2 style="font-size:22px;font-weight:700;color:var(--text-primary);letter-spacing:-0.02em;">Browse Servers</h2>
          <p style="margin-top:4px;font-size:13px;color:var(--text-tertiary);">
            <span id="results-count" style="color:var(--accent-secondary);font-weight:600;font-variant-numeric:tabular-nums;">{totalServers}</span> open-source MCP servers
          </p>
        </div>

        <!-- Search bar -->
        <div style="position:relative;width:100%;max-width:320px;">
          <div style="position:absolute;left:12px;top:50%;transform:translateY(-50%);pointer-events:none;color:var(--text-muted);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <input
            id="search-input"
            type="search"
            placeholder="Search servers, tags..."
            autocomplete="off"
            spellcheck="false"
            style="width:100%;padding:10px 14px 10px 38px;font-size:13px;font-family:inherit;color:var(--text-primary);background:rgba(255,255,255,0.03);border:1px solid var(--border-default);border-radius:10px;outline:none;transition:all 0.2s;"
            onfocus="this.style.borderColor='rgba(99,102,241,0.4)';this.style.background='rgba(255,255,255,0.05)';this.style.boxShadow='0 0 0 3px rgba(99,102,241,0.08)'"
            onblur="this.style.borderColor='var(--border-default)';this.style.background='rgba(255,255,255,0.03)';this.style.boxShadow='none'"
          />
        </div>
      </div>

      <!-- Category filter pills -->
      <div id="category-filters" style="margin-top:16px;display:flex;flex-wrap:wrap;gap:6px;">
        {categories.map((cat) => (
          <button
            class="category-btn"
            data-category={cat}
            data-active={cat === 'All' ? 'true' : 'false'}
            style={`padding:6px 14px;font-size:12px;font-family:inherit;font-weight:500;border-radius:8px;cursor:pointer;transition:all 0.2s;border:1px solid ${cat === 'All' ? 'rgba(99,102,241,0.3)' : 'var(--border-default)'};background:${cat === 'All' ? 'rgba(99,102,241,0.1)' : 'transparent'};color:${cat === 'All' ? '#818cf8' : 'var(--text-tertiary)'};`}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- No results state -->
    <div id="no-results" style="display:none;padding:80px 24px;text-align:center;">
      <div style="font-size:40px;margin-bottom:12px;opacity:0.4;">⌀</div>
      <p style="color:var(--text-secondary);font-weight:500;font-size:15px;">No servers found</p>
      <p style="color:var(--text-muted);font-size:13px;margin-top:6px;">Try adjusting your search or category filter</p>
    </div>

    <!-- ─── Card Grid ─── -->
    <div id="registry-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px;">
      {registry.map((server, index) => {
        const colors = categoryColors[server.category] || { text: '#a0a0c0', bg: 'rgba(160,160,192,0.08)', border: 'rgba(160,160,192,0.15)' };
        const icon = categoryIcons[server.category] || '◈';

        return (
          <article
            class="registry-card glass-card"
            data-name={server.name.toLowerCase()}
            data-description={server.description.toLowerCase()}
            data-category={server.category}
            data-tags={server.tags.join(' ').toLowerCase()}
            style={`border-radius:16px;padding:24px;display:flex;flex-direction:column;cursor:default;`}
          >
            <!-- Card top row -->
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:14px;">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                  <h3 style="font-size:15px;font-weight:600;color:var(--text-primary);letter-spacing:-0.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{server.name}</h3>
                  {server.featured && (
                    <span style={`display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:100px;font-size:10px;font-weight:600;color:${colors.text};background:${colors.bg};border:1px solid ${colors.border};`}>
                      ★ Featured
                    </span>
                  )}
                </div>
                <p style="margin-top:3px;font-size:12px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;">
                  {server.author}
                </p>
              </div>
              <span style={`flex-shrink:0;display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:8px;font-size:11px;font-weight:500;color:${colors.text};background:${colors.bg};border:1px solid ${colors.border};`}>
                <span style="font-size:10px;">{icon}</span>
                {server.category}
              </span>
            </div>

            <!-- Description -->
            <p class="line-clamp-3" style="flex:1;font-size:13px;color:var(--text-tertiary);line-height:1.65;">
              {server.description}
            </p>

            <!-- Tags -->
            <div style="display:flex;flex-wrap:wrap;gap:5px;margin-top:16px;">
              {server.tags.slice(0, 4).map((tag) => (
                <span style="padding:3px 8px;border-radius:6px;font-size:11px;font-family:'JetBrains Mono',monospace;font-weight:500;color:var(--text-muted);background:rgba(255,255,255,0.03);border:1px solid var(--border-subtle);">
                  #{tag}
                </span>
              ))}
            </div>

            <!-- Card footer -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;padding-top:16px;border-top:1px solid var(--border-subtle);">
              <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:500;">{server.stars >= 1000 ? (server.stars / 1000).toFixed(1) + 'k' : server.stars}</span>
              </div>
              <a
                href={server.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:8px;font-size:12px;font-weight:500;color:var(--text-secondary);text-decoration:none;background:rgba(255,255,255,0.03);border:1px solid var(--border-default);transition:all 0.2s;"
                onmouseover="this.style.borderColor='rgba(99,102,241,0.3)';this.style.color='#818cf8';this.style.background='rgba(99,102,241,0.06)'"
                onmouseout="this.style.borderColor='var(--border-default)';this.style.color='var(--text-secondary)';this.style.background='rgba(255,255,255,0.03)'"
              >
                View on GitHub
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!--                        HOW IT WORKS SECTION                       -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" style="border-top:1px solid var(--border-subtle);background:linear-gradient(180deg,rgba(99,102,241,0.02) 0%,transparent 100%);">
    <div style="max-width:1200px;margin:0 auto;padding:80px 24px;">
      <!-- Section header -->
      <div style="text-align:center;margin-bottom:48px;">
        <p style="font-size:12px;font-weight:600;color:var(--accent-secondary);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">Integration Guide</p>
        <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);letter-spacing:-0.02em;">Three steps to connect</h2>
        <p style="margin-top:8px;font-size:14px;color:var(--text-tertiary);">From discovery to production in minutes</p>
      </div>

      <!-- Steps -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
        {[
          {
            num: '01',
            title: 'Discover',
            desc: 'Search the registry by category, tag, or use case. Every server is open-source, free, and community-vetted.',
            gradient: 'linear-gradient(135deg, #6366f1, #818cf8)',
          },
          {
            num: '02',
            title: 'Install',
            desc: 'One-line install via npm, pip, or uv. Follow the GitHub README for environment-specific setup.',
            gradient: 'linear-gradient(135deg, #818cf8, #22d3ee)',
          },
          {
            num: '03',
            title: 'Connect',
            desc: 'Add the server to your claude_desktop_config.json, LangGraph agent, or CrewAI tool list.',
            gradient: 'linear-gradient(135deg, #22d3ee, #34d399)',
          },
        ].map((step) => (
          <div class="glass-card" style="border-radius:16px;padding:28px;">
            <div style={`display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:12px;background:${step.gradient};font-size:14px;font-weight:700;color:white;margin-bottom:20px;box-shadow:0 4px 16px rgba(99,102,241,0.2);`}>
              {step.num}
            </div>
            <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:8px;">{step.title}</h3>
            <p style="font-size:13px;color:var(--text-tertiary);line-height:1.7;">{step.desc}</p>
          </div>
        ))}
      </div>

      <!-- Code example -->
      <div class="glass-card" style="margin-top:32px;border-radius:16px;overflow:hidden;">
        <!-- Tab bar -->
        <div style="display:flex;align-items:center;gap:8px;padding:12px 20px;border-bottom:1px solid var(--border-subtle);background:rgba(0,0,0,0.2);">
          <div style="width:10px;height:10px;border-radius:50%;background:#fb5c5c;"></div>
          <div style="width:10px;height:10px;border-radius:50%;background:#fbbd2e;"></div>
          <div style="width:10px;height:10px;border-radius:50%;background:#27cb3f;"></div>
          <span style="margin-left:12px;font-size:12px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;">claude_desktop_config.json</span>
        </div>
        <!-- Code -->
        <div style="padding:20px 24px;overflow-x:auto;">
          <pre style="font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.8;color:var(--text-tertiary);margin:0;"><code><span style="color:var(--text-muted);">{'{'}</span>
  <span style="color:#818cf8;">"mcpServers"</span><span style="color:var(--text-muted);">: {'{'}</span>
    <span style="color:#22d3ee;">"sqlite"</span><span style="color:var(--text-muted);">: {'{'}</span>
      <span style="color:#34d399;">"command"</span><span style="color:var(--text-muted);">: </span><span style="color:#fbbf24;">"uvx"</span><span style="color:var(--text-muted);">,</span>
      <span style="color:#34d399;">"args"</span><span style="color:var(--text-muted);">: </span><span style="color:var(--text-muted);">[</span><span style="color:#fbbf24;">"mcp-server-sqlite"</span><span style="color:var(--text-muted);">,</span> <span style="color:#fbbf24;">"--db-path"</span><span style="color:var(--text-muted);">,</span> <span style="color:#fbbf24;">"./data.db"</span><span style="color:var(--text-muted);">]</span>
    <span style="color:var(--text-muted);">{'}'}</span><span style="color:var(--text-muted);">,</span>
    <span style="color:#22d3ee;">"github"</span><span style="color:var(--text-muted);">: {'{'}</span>
      <span style="color:#34d399;">"command"</span><span style="color:var(--text-muted);">: </span><span style="color:#fbbf24;">"npx"</span><span style="color:var(--text-muted);">,</span>
      <span style="color:#34d399;">"args"</span><span style="color:var(--text-muted);">: </span><span style="color:var(--text-muted);">[</span><span style="color:#fbbf24;">"-y"</span><span style="color:var(--text-muted);">,</span> <span style="color:#fbbf24;">"@modelcontextprotocol/server-github"</span><span style="color:var(--text-muted);">]</span>
    <span style="color:var(--text-muted);">{'}'}</span>
  <span style="color:var(--text-muted);">{'}'}</span>
<span style="color:var(--text-muted);">{'}'}</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!--                         SPONSORS SECTION                           -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <section style="max-width:1200px;margin:40px auto;padding:0 24px;" class="animate-fade-up">
    <div class="glass-card" style="padding:28px;border-radius:16px;border:1px solid var(--border-default);">
      
      <!-- Section Header -->
      <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:24px;flex-wrap:wrap;">
        <div>
