---
import Layout from '../layouts/Layout.astro';
import registry from '../data/registry.json';

const categories = ['All', ...new Set(registry.map((s) => s.category))].sort((a, b) =>
  a === 'All' ? -1 : b === 'All' ? 1 : a.localeCompare(b)
);

const totalServers = registry.length;
const totalCategories = categories.length - 1;
---

<Layout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background grid + glow -->
    <div class="absolute inset-0 bg-grid-pattern opacity-100" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[600px] w-[900px] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(6,182,212,0.07) 0%, rgba(59,130,246,0.04) 40%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-7xl px-4 pt-20 pb-16 sm:px-6 lg:px-8">
      <!-- Status badge -->
      <div class="mb-6 flex justify-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 px-3.5 py-1.5 text-xs font-medium text-cyan-400">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan-500"></span>
          </span>
          Community Registry · {totalServers} servers · 100% Free & Open Source
        </span>
      </div>

      <!-- Headline -->
      <div class="text-center">
        <h1
          class="mx-auto max-w-4xl text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl"
          style="letter-spacing: -0.02em;"
        >
          The Open Registry for
          <span
            class="block mt-1"
            style="background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 50%, #8b5cf6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
          >
            MCP Servers
          </span>
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-base text-slate-400 sm:text-lg leading-relaxed">
          Standardized tool integration for autonomous agents and DevSecOps workflows.
          Find, compare, and connect free open-source MCP servers — no paywalls, no enterprise gates.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="#registry"
            class="inline-flex items-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold text-white"
            style="background: linear-gradient(135deg, #06b6d4, #3b82f6); box-shadow: 0 4px 20px rgba(6,182,212,0.3);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
              <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Browse Registry
          </a>
          <a
            href="https://github.com/freemcpin/registry"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-slate-700 bg-slate-800/50 px-5 py-3 text-sm font-semibold text-slate-300 transition-all hover:border-slate-600 hover:bg-slate-700/50 hover:text-white"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="mt-14 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {[
          { label: 'MCP Servers', value: totalServers + '+', icon: '◈' },
          { label: 'Categories', value: totalCategories, icon: '⬡' },
          { label: 'License', value: '100% Free', icon: '✦' },
          { label: 'Backend Cost', value: '$0/mo', icon: '∞' },
        ].map((stat) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 text-center backdrop-blur-sm">
            <div class="text-lg text-cyan-400 mb-1 font-mono">{stat.icon}</div>
            <div class="text-xl font-bold text-white">{stat.value}</div>
            <div class="text-xs text-slate-500 mt-0.5">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Registry Section -->
  <section id="registry" class="mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-bold text-white">Browse Servers</h2>
          <p class="mt-1 text-sm text-slate-500">
            <span id="results-count">{totalServers}</span> open-source MCP servers · community maintained
          </p>
        </div>
        <!-- Search -->
        <div class="relative w-full sm:w-72">
          <div class="pointer-events-none absolute inset-y-0 left-3 flex items-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-slate-500">
              <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
              <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <input
            id="search-input"
            type="search"
            placeholder="Search servers, tags, tools..."
            class="w-full rounded-xl border border-slate-700 bg-slate-800/60 py-2.5 pl-9 pr-4 text-sm text-slate-200 placeholder-slate-500 outline-none transition-all focus:border-cyan-500/50 focus:bg-slate-800 focus:ring-2 focus:ring-cyan-500/20"
            autocomplete="off"
            spellcheck="false"
          />
        </div>
      </div>

      <!-- Category Filters -->
      <div class="mt-4 flex flex-wrap gap-2" id="category-filters">
        {categories.map((cat) => (
          <button
            class="category-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition-all"
            data-category={cat}
            data-active={cat === 'All' ? 'true' : 'false'}
            style={cat === 'All' ? 'border-color: rgba(6,182,212,0.4); background: rgba(6,182,212,0.1); color: #06b6d4;' : 'border-color: rgb(30,41,59); background: transparent; color: rgb(100,116,139);'}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- No results state -->
    <div id="no-results" class="hidden py-24 text-center">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-slate-400 font-medium">No servers found</p>
      <p class="text-slate-600 text-sm mt-1">Try a different search term or category</p>
    </div>

    <!-- Card Grid -->
    <div id="registry-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {registry.map((server, index) => {
        const categoryColors: Record<string, string> = {
          Database: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
          Development: 'text-blue-400 bg-blue-500/10 border-blue-500/20',
          Security: 'text-rose-400 bg-rose-500/10 border-rose-500/20',
          DevOps: 'text-orange-400 bg-orange-500/10 border-orange-500/20',
          Utilities: 'text-purple-400 bg-purple-500/10 border-purple-500/20',
          Search: 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20',
          Communication: 'text-pink-400 bg-pink-500/10 border-pink-500/20',
          Cloud: 'text-sky-400 bg-sky-500/10 border-sky-500/20',
        };
        const badgeClass = categoryColors[server.category] || 'text-slate-400 bg-slate-500/10 border-slate-500/20';

        return (
          <article
            class="registry-card group relative flex flex-col rounded-2xl border border-slate-800 bg-slate-900/70 p-5 backdrop-blur-sm transition-all duration-300 hover:border-cyan-500/30 hover:bg-slate-900"
            data-name={server.name.toLowerCase()}
            data-description={server.description.toLowerCase()}
            data-category={server.category}
            data-tags={server.tags.join(' ').toLowerCase()}
            style={`animation-delay: ${index * 40}ms`}
          >
            <!-- Featured glow -->
            {server.featured && (
              <div
                class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity group-hover:opacity-100"
                style="background: radial-gradient(ellipse at top left, rgba(6,182,212,0.05) 0%, transparent 60%);"
                aria-hidden="true"
              />
            )}

            <!-- Card Header -->
            <div class="mb-3 flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="text-sm font-semibold text-white leading-tight truncate">{server.name}</h3>
                  {server.featured && (
                    <span class="inline-flex shrink-0 items-center rounded-full border border-cyan-500/30 bg-cyan-500/10 px-1.5 py-0.5 text-[10px] font-medium text-cyan-400">
                      ★ Featured
                    </span>
                  )}
                </div>
                <p class="mt-0.5 text-xs text-slate-500 font-mono">by {server.author}</p>
              </div>
              <span class={`shrink-0 inline-flex items-center rounded-lg border px-2 py-1 text-[11px] font-medium ${badgeClass}`}>
                {server.category}
              </span>
            </div>

            <!-- Description -->
            <p class="flex-1 text-sm text-slate-400 leading-relaxed line-clamp-3">
              {server.description}
            </p>

            <!-- Tags -->
            <div class="mt-4 flex flex-wrap gap-1.5">
              {server.tags.slice(0, 4).map((tag) => (
                <span class="rounded-md bg-slate-800 px-2 py-0.5 text-[11px] font-mono text-slate-500 border border-slate-700/50">
                  #{tag}
                </span>
              ))}
            </div>

            <!-- Footer -->
            <div class="mt-4 flex items-center justify-between border-t border-slate-800/60 pt-4">
              <div class="flex items-center gap-1.5 text-xs text-slate-500">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" class="text-slate-600">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
                <span class="font-mono">{server.stars >= 1000 ? (server.stars / 1000).toFixed(1) + 'k' : server.stars}</span>
                <span>stars</span>
              </div>
              <a
                href={server.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-800/60 px-3 py-1.5 text-xs font-medium text-slate-300 transition-all hover:border-cyan-500/40 hover:bg-slate-700 hover:text-cyan-400"
              >
                View on GitHub
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- How to Use Section -->
  <section class="border-t border-slate-800/60 bg-slate-900/30">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-white">How to Use MCP Servers</h2>
        <p class="mt-2 text-slate-500 text-sm">Integrate any server into your agent stack in minutes</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            step: '01',
            title: 'Find a Server',
            desc: 'Search the registry by category or use case. All servers are open-source and free.',
            color: 'from-cyan-500 to-blue-600',
          },
          {
            step: '02',
            title: 'Install via npm / pip / uv',
            desc: 'Follow the GitHub README. Most servers support one-line install via package managers.',
            color: 'from-blue-500 to-purple-600',
          },
          {
            step: '03',
            title: 'Connect to your Agent',
            desc: 'Configure in your claude_desktop_config.json or LangGraph/CrewAI agent tool list.',
            color: 'from-purple-500 to-pink-600',
          },
        ].map((item) => (
          <div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6">
            <div class={`inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br ${item.color} text-base font-bold text-white mb-4`}>
              {item.step}
            </div>
            <h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Code snippet -->
      <div class="mt-8 rounded-2xl border border-slate-800 bg-slate-950 p-5 overflow-x-auto">
        <p class="text-xs text-slate-500 mb-3 font-mono">// Example: claude_desktop_config.json</p>
        <pre class="text-sm text-slate-300 font-mono leading-relaxed"><code><span class="text-slate-600">{'{'}</span>
  <span class="text-cyan-400">"mcpServers"</span><span class="text-slate-600">: {'{'}</span>
    <span class="text-blue-400">"sqlite"</span><span class="text-slate-600">: {'{'}</span>
      <span class="text-emerald-400">"command"</span><span class="text-slate-400">: </span><span class="text-amber-300">"uvx"</span><span class="text-slate-400">,</span>
      <span class="text-emerald-400">"args"</span><span class="text-slate-400">: </span><span class="text-slate-600">[</span><span class="text-amber-300">"mcp-server-sqlite"</span><span class="text-slate-600">]</span>
    <span class="text-slate-600">{'}'}</span><span class="text-slate-400">,</span>
    <span class="text-blue-400">"github"</span><span class="text-slate-600">: {'{'}</span>
      <span class="text-emerald-400">"command"</span><span class="text-slate-400">: </span><span class="text-amber-300">"npx"</span><span class="text-slate-400">,</span>
      <span class="text-emerald-400">"args"</span><span class="text-slate-400">: </span><span class="text-slate-600">[</span><span class="text-amber-300">"-y"</span><span class="text-slate-400">, </span><span class="text-amber-300">"@modelcontextprotocol/server-github"</span><span class="text-slate-600">]</span>
    <span class="text-slate-600">{'}'}</span>
  <span class="text-slate-600">{'}'}</span>
<span class="text-slate-600">{'}'}</span></code></pre>
      </div>
    </div>
  </section>
</Layout>

<script>
  // ─── Client-side search & filter ─────────────────────────────────────────
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const categoryBtns = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const cards = document.querySelectorAll<HTMLElement>('.registry-card');
  const resultsCount = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');

  let activeCategory = 'All';
  let searchQuery = '';

  function filterCards() {
    let visible = 0;

    cards.forEach((card) => {
      const name = card.dataset.name || '';
      const desc = card.dataset.description || '';
      const category = card.dataset.category || '';
      const tags = card.dataset.tags || '';

      const matchesSearch =
        !searchQuery ||
        name.includes(searchQuery) ||
        desc.includes(searchQuery) ||
        tags.includes(searchQuery) ||
        category.toLowerCase().includes(searchQuery);

      const matchesCategory = activeCategory === 'All' || category === activeCategory;

      if (matchesSearch && matchesCategory) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });

    if (resultsCount) resultsCount.textContent = String(visible);
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
  }

  // Search input handler (debounced)
  let debounceTimer: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filterCards();
    }, 150);
  });

  // Category button handler
  categoryBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category || 'All';

      categoryBtns.forEach((b) => {
        const isActive = b.dataset.category === activeCategory;
        b.setAttribute('data-active', String(isActive));
        if (isActive) {
          b.style.borderColor = 'rgba(6,182,212,0.4)';
          b.style.background = 'rgba(6,182,212,0.1)';
          b.style.color = '#06b6d4';
        } else {
          b.style.borderColor = 'rgb(30,41,59)';
          b.style.background = 'transparent';
          b.style.color = 'rgb(100,116,139)';
        }
      });

      filterCards();
    });
  });

  // Animate cards on load
  cards.forEach((card, i) => {
    card.style.opacity = '0';
    card.style.transform = 'translateY(16px)';
    setTimeout(() => {
      card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }, i * 40);
  });
</script>
